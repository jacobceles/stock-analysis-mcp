# Required for ADK
LITE_LLM_MODEL=provider/model-name
LITE_LLM_API_KEY=X

# Optional: Required for Google Services overrides
GOOGLE_API_KEY=X

# Optional: Required only for Reddit Sentiment features
REDDIT_CLIENT_ID=X
REDDIT_CLIENT_SECRET=X
REDDIT_USER_AGENT=stock-analysis-mcp/1.0

# Optional Configuration Defaults
HOST=0.0.0.0
PORT=8080
MCP_URL=http://mcp:8000/sse
LOG_FORMAT=color
OPTIONAL_INDICATOR_TOOLS=adx,psar_up,psar_down,aroon_up,aroon_down