{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Setup Environment",
            "type": "shell",
            "command": "uv sync --all-groups && if [ -d .git ]; then if command -v prek >/dev/null 2>&1; then prek install; else echo 'WARNING: prek not found. Install: brew install j178/tap/prek (macOS) or curl -fsSL https://raw.githubusercontent.com/j178/prek/main/install.sh | sh (Linux) or cargo install prek'; fi; fi",
            "problemMatcher": [],
            "group": "build"
        },
        {
            "label": "Format Code",
            "type": "shell",
            "command": "uv run ruff format",
            "problemMatcher": [],
            "group": "build"
        },
        {
            "label": "Lint Code (Ruff)",
            "type": "shell",
            "command": "uv run ruff check --fix",
            "problemMatcher": [],
            "group": "build"
        },
        {
            "label": "Typecheck (Mypy & Pyrefly)",
            "type": "shell",
            "command": "uv run mypy . && uv run pyrefly check .",
            "problemMatcher": [],
            "group": "build"
        },
        {
            "label": "Run Tests",
            "type": "shell",
            "command": "uv run pytest",
            "problemMatcher": [],
            "group": "build"
        },
        {
            "label": "Docker: Build Images",
            "type": "shell",
            "command": "docker compose -f docker/compose.yml build",
            "problemMatcher": [],
            "group": "build"
        },
        {
            "label": "Docker: Start Services",
            "type": "shell",
            "command": "docker compose -f docker/compose.yml up -d",
            "problemMatcher": [],
            "group": "build"
        },
        {
            "label": "Docker: Stop Services",
            "type": "shell",
            "command": "docker compose -f docker/compose.yml down",
            "problemMatcher": [],
            "group": "build"
        },
        {
            "label": "Docker: Tail Logs",
            "type": "shell",
            "command": "docker compose -f docker/compose.yml logs -f",
            "problemMatcher": [],
            "group": "build"
        }
    ]
}
